// SQLite for local preview. To switch to Postgres:
//   1. Set provider = "postgresql"
//   2. Set DATABASE_URL to a Postgres connection string
//   3. Convert string fields back to enums (see git history for original)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// String enums — allowed values:
//   Role:          "ADMIN" | "BRAND"
//   ProductStatus: "ACTIVE" | "INACTIVE"
//   VideoStatus:   "DRAFT" | "ACTIVE" | "INACTIVE"
//   WidgetMode:    "inline" | "floating" | "feed"
//   EventType:     "IMPRESSION" | "VIEW" | "TAG_CLICK" | "CTA_CLICK"

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("BRAND")
  brandId      String?
  brand        Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([brandId])
}

model Brand {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  domain    String?
  disabled  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  products       Product[]
  videos         Video[]
  widgetInstalls WidgetInstall[]
  events         AnalyticsEvent[]
}

model Product {
  id         String   @id @default(cuid())
  brandId    String
  brand      Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name       String
  price      Float
  imageUrl   String
  productUrl String
  sku        String?
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tags   VideoProductTag[]
  events AnalyticsEvent[]

  @@index([brandId])
  @@index([brandId, status])
}

model Video {
  id           String   @id @default(cuid())
  brandId      String
  brand        Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  videoUrl     String
  thumbnailUrl String?
  status       String   @default("DRAFT")
  disabled     Boolean  @default(false)
  durationSec  Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tags   VideoProductTag[]
  events AnalyticsEvent[]

  @@index([brandId])
  @@index([brandId, status, disabled])
}

model VideoProductTag {
  id        String   @id @default(cuid())
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  x         Float
  y         Float
  startTime Float    @default(0)
  endTime   Float
  createdAt DateTime @default(now())

  @@index([videoId])
  @@index([productId])
}

model WidgetInstall {
  id          String   @id @default(cuid())
  brandId     String
  brand       Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  domain      String
  mode        String
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  @@unique([brandId, domain, mode])
  @@index([brandId])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  brandId   String
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  videoId   String?
  video     Video?   @relation(fields: [videoId], references: [id], onDelete: SetNull)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  type      String
  domain    String?
  ip        String?
  ua        String?
  createdAt DateTime @default(now())

  @@index([brandId, createdAt])
  @@index([brandId, type])
  @@index([videoId])
  @@index([productId])
}

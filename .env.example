# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/avori?schema=public"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Storage provider: local | s3 | r2 | mux | uploadcare
STORAGE_PROVIDER="local"
LOCAL_UPLOAD_DIR="./public/uploads"

# Future provider creds (unused while STORAGE_PROVIDER=local)
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# R2_ACCOUNT_ID=""
# R2_BUCKET=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# MUX_TOKEN_ID=""
# MUX_TOKEN_SECRET=""
# UPLOADCARE_PUBLIC_KEY=""
# UPLOADCARE_SECRET_KEY=""

# Upload limits
MAX_VIDEO_BYTES="200000000"
MAX_IMAGE_BYTES="10000000"

# Rate limiting (events per IP per minute)
EVENT_RATE_LIMIT="120"
